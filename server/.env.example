# Copy this to .env for local development
# DO NOT commit .env to git

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Leave empty locally (uses SQLite automatically)
DATABASE_URL=

# Your Render frontend URL (set after deploying frontend)
FRONTEND_URL=https://blooddrop-frontend.onrender.com
